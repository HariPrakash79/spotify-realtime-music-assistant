{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Normalize Deezer (Limited)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/normalize_to_stage.py",
      "console": "integratedTerminal",
      "args": [
        "--dataset",
        "deezer_recsys25_archive",
        "--max-records",
        "100000",
        "--deezer-max-members",
        "10",
        "--tmp-dir",
        "D:\\temp",
        "--audit-dir",
        "artifacts/deezer_audit"
      ],
      "env": {
        "AWS_PROFILE": "spotify",
        "AWS_REGION": "us-east-1",
        "DATA_BUCKET": "spotify-project-hari-2026",
        "S3_PREFIX": "music-assistant"
      }
    },
    {
      "name": "Normalize Deezer (Scale)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/normalize_to_stage.py",
      "console": "integratedTerminal",
      "args": [
        "--dataset",
        "deezer_recsys25_archive",
        "--max-records",
        "800000",
        "--deezer-max-members",
        "20",
        "--tmp-dir",
        "D:\\temp",
        "--audit-dir",
        "artifacts/deezer_audit"
      ],
      "env": {
        "AWS_PROFILE": "spotify",
        "AWS_REGION": "us-east-1",
        "DATA_BUCKET": "spotify-project-hari-2026",
        "S3_PREFIX": "music-assistant"
      }
    },
    {
      "name": "Produce Deezer -> Kafka (300k)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/produce_listen_events.py",
      "console": "integratedTerminal",
      "args": [
        "--source",
        "deezer_recsys25_archive",
        "--topic",
        "listen_events_raw",
        "--max-records",
        "300000",
        "--sample-strategy",
        "random",
        "--randomize-rows",
        "--seed",
        "42",
        "--max-records-per-user",
        "500"
      ],
      "env": {
        "AWS_PROFILE": "spotify",
        "AWS_REGION": "us-east-1",
        "DATA_BUCKET": "spotify-project-hari-2026",
        "S3_PREFIX": "music-assistant",
        "KAFKA_BOOTSTRAP_SERVERS": "localhost:9092"
      }
    },
    {
      "name": "Inspect Ingested Data (Export CSV/JSON)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/inspect_ingested_data.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--output-dir",
        "artifacts/inspection",
        "--sample-events",
        "1000",
        "--top-users",
        "200",
        "--top-genres",
        "200"
      ]
    },
    {
      "name": "Consume Kafka -> Postgres (300k)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/consume_listen_events_to_postgres.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--bootstrap-servers",
        "localhost:9092",
        "--topic",
        "listen_events_raw",
        "--group-id",
        "music-listen-events-sink-v-deezer",
        "--max-messages",
        "300000",
        "--insert-batch-size",
        "1000"
      ]
    },
    {
      "name": "Check Data Targets (500k/1k/50k)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/check_data_targets.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--target-events",
        "500000",
        "--target-users",
        "1000",
        "--target-tracks",
        "50000"
      ]
    },
    {
      "name": "Run Recommendation API",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/recommendation_api.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Build Track Vibe Features",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/build_track_vibe_features.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--include-unknown"
      ]
    },
    {
      "name": "Call Recommendation API (Metrics)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/recommendation_client.py",
      "console": "integratedTerminal",
      "args": [
        "--query",
        "metrics"
      ]
    },
    {
      "name": "Run Chat Assistant",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/chat_assistant.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Run LLM Music Assistant",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/llm_music_assistant.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Run Bedrock Music Assistant",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/bedrock_music_assistant.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Run LangChain Bedrock Assistant",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/langchain_bedrock_assistant.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Generate User Profiles (Real Names)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/generate_user_profiles.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--max-users",
        "1000"
      ]
    },
    {
      "name": "Train Personalized MF Model",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/train_personalized_mf.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--epochs",
        "8",
        "--factors",
        "48",
        "--top-k",
        "100"
      ]
    },
    {
      "name": "Evaluate Recommendation Quality",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/evaluate_recommendation_quality.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--source",
        "both",
        "--k",
        "20",
        "--holdout-size",
        "5",
        "--min-user-events",
        "20"
      ]
    }
  ]
}
