POSTGRES_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
PGSSLMODE=require

# Optional alternatives if you don't use POSTGRES_DSN:
# PGHOST=your-rds-endpoint.amazonaws.com
# PGPORT=5432
# PGDATABASE=your_db_name
# PGUSER=your_db_user
# PGPASSWORD=your_db_password

# Optional for local API client scripts:
# RECOMMENDATION_API_BASE_URL=http://localhost:8000
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# AWS_PROFILE=spotify

# Optional feedback consensus thresholds for /feedback/vibe:
# VIBE_FEEDBACK_MIN_USERS=15
# VIBE_FEEDBACK_MIN_TOP_SHARE=0.70
# VIBE_FEEDBACK_MIN_MARGIN=0.15

# Optional: control recommendation source priority in /recs endpoint.
# Priority order is: hybrid -> mf -> trending (dense only if explicitly enabled).
# USE_HYBRID_RECS=true
# USE_ML_RECS=true
# USE_DENSE_RECS=false
